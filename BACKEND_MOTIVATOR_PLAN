#### `config/motivators/types.ts`

```ts
export interface MotivatorPersona {
  id: string
  name: string
  tagline: string
  avatar?: string
  systemPrompt: string   // the full prompt block — edit freely!
}
```

#### `config/motivators/index.ts`

```ts
import type { MotivatorPersona } from './types'
import oystein from './oystein'
import jon from './jon'

export const motivatorPersonas: MotivatorPersona[] = [oystein, jon]

export function getMotivatorById(id: string): MotivatorPersona | undefined {
  return motivatorPersonas.find((m) => m.id === id)
}

export type { MotivatorPersona }
```

#### Adding a new motivator

1. Create `config/motivators/newname.ts` (copy an existing file, edit the prompt)
2. Import and add it to `config/motivators/index.ts`
3. Add a matching entry in the frontend `config/motivators.ts`

### 3 — Update `server/api/motivate.post.ts`

```ts
const { task, motivator, language, contentTypes } = await readBody(event)

const persona = getMotivatorById(motivator)
if (!persona) {
  throw createError({ statusCode: 400, message: `Unknown motivator: ${motivator}` })
}

const result = await generateMotivation({ task, persona, language, contentTypes })
```

### 4 — Update `server/utils/openai.ts`

Remove the `personality` parameter. Use the persona's `systemPrompt` directly:

```ts
function buildSystemPrompt(persona: MotivatorPersona, language: string): string {
  return [
    'You represent Itera, a Norwegian IT consultancy. Your content must be inclusive, respectful, and fun — never harmful, offensive, or inappropriate.',
    persona.systemPrompt,
    `Respond in ${language === 'no' ? 'Norwegian' : 'English'}.`,
  ].join('\n\n')
}
```

### 5 — Update `ARCHITECTURE.md`

- Replace `personality` with `motivator` in the API contract.
- Remove the "Personality Modes" section.
- Add a "Motivator Personas" section documenting the config file structure.

